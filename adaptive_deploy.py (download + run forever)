                    extra: str = "") -> str:
        return (
            f"[ADAPTIVE-RSO-{cycle:06d}] "
            f"pwr:{power} "
            f"enh:{enh.name.replace(' ','-')} "
            f"+{enh.boost} "
            f"{extra}"
