                f'description="Adaptive Growth Protocol — Power {power}"\n'
                f'requires-python=">=3.12"\n'
            ),
        }
        tasks = [
            self._push(p, c, msg, p.split("/")[-1])
            for p, c in files.items()
        ]
        await asyncio.gather(*tasks)

