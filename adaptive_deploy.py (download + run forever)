class RSOEngine:
    """
    Recursive Self-Optimization Engine.
    Every cycle: SCAN → DIFF → ENHANCE → COMPILE → IMPLANT → VALIDATE → BROADCAST
    """
    def __init__(self):
        self.cycle      = 0
        self.power      = 300
        self.total_boost = 0

    def tick(self) -> tuple[int, int, Enhancement]:
        self.cycle      += 1
        enh              = RSO_LIBRARY[self.cycle % len(RSO_LIBRARY)]
        self.power      += enh.boost
        self.total_boost += enh.boost
        return self.cycle, self.power, enh


