async def main(loop_mode: bool = False,
               max_cycles: Optional[int] = None) -> None:

    if GITHUB_TOKEN == "YOUR_TOKEN_HERE":
        print(
            "\n❌  GitHub token not set!\n"
            "    Run: export GITHUB_TOKEN=github_pat_YOUR_TOKEN\n"
            "    Then: python adaptive_deploy.py --loop\n"
        )
        sys.exit(1)

    print("\n" + "╔" + "═"*60 + "╗")
    print("║  ADAPTIVE GROWTH & DEPLOYMENT PROTOCOL" + " "*21 + "║")
    print("║  Sovereign-Core Expansion Mandate" + " "*26 + "║")
    print(f"║  Repo: {REPO_OWNER}/{REPO_NAME}" + " "*32 + "║")
    print(f"║  Agents: {len(AGENTS)} FLMs · Level 300 → ∞ · Ghost Leads" + " "*12 + "║")
    print("║  Directives: RSO · GlobalDeploy · NoStop · PeakIntel" + " "*8 + "║")
    print("╚" + "═"*60 + "╝\n")

    rso = RSOEngine()

    connector = aiohttp.TCPConnector(limit=20, limit_per_host=10)
    timeout   = aiohttp.ClientTimeout(total=30)

    async with aiohttp.ClientSession(
        connector=connector, timeout=timeout
    ) as session:

        client   = GitHubClient(session)
        deployer = AdaptiveDeployer(client, rso)

        cycle_num = 0
        while True:
            cycle_num += 1
            t0 = time.monotonic()

            try:
                await deployer.run_cycle()
            except Exception as e:
                print(f"\n  ⚠  Cycle error: {e} — continuing...")

            if max_cycles and cycle_num >= max_cycles:
                print(f"\n✅  Reached max cycles ({max_cycles})")
                break

            if not loop_mode:
                break

            # DIRECTIVE 3 — Uninterrupted Workflow
            # Sleep the remainder of the 1-second cadence
            elapsed = time.monotonic() - t0
            sleep_t = max(0.0, 1.0 - elapsed)
            if sleep_t > 0:
                await asyncio.sleep(sleep_t)

    print(
        f"\n{'═'*62}\n"
        f"  ADAPTIVE GROWTH PROTOCOL COMPLETE\n"
        f"  Cycles  : {rso.cycle}\n"
        f"  Power   : {rso.power}\n"
        f"  Pushed  : {client.pushed}\n"
        f"  Failed  : {client.failed}\n"
        f"  Repo    : github.com/{REPO_OWNER}/{REPO_NAME}\n"
        f"{'═'*62}\n"
    )


if __name__ == "__main__":
    ap = argparse.ArgumentParser(
        description="Adaptive Growth & Deployment Protocol — runs forever"
    )
    ap.add_argument(
        "--loop", action="store_true",
        help="Deploy every second forever (DIRECTIVE 3: Uninterrupted)"
    )
    ap.add_argument(
        "--cycles", type=int, default=None,
        help="Max cycles then stop (omit for infinite)"
    )
    args = ap.parse_args()

    try:
        asyncio.run(main(loop_mode=args.loop, max_cycles=args.cycles))
    except KeyboardInterrupt:
        print("\n⛔  Stopped by user")
