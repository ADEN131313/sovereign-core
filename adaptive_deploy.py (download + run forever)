# GITHUB API LAYER
# ══════════════════════════════════════════════════════════════════

class GitHubClient:
    def __init__(self, session: aiohttp.ClientSession):
        self.session   = session
        self.sha_cache: dict[str, str] = {}
        self.pushed    = 0
        self.failed    = 0
        self.rate_hits = 0

    async def get_sha(self, path: str) -> Optional[str]:
        if path in self.sha_cache:
            return self.sha_cache[path]
        url = f"{BASE_URL}/contents/{path}?ref={BRANCH}"
        try:
            async with self.session.get(url, headers=HEADERS) as r:
                if r.status == 200:
                    d = await r.json()
                    sha = d.get("sha", "")
                    self.sha_cache[path] = sha
                    return sha
                if r.status == 429:
                    self.rate_hits += 1
                    await asyncio.sleep(2)
        except Exception:
            pass
        return None

    async def push(self, path: str, content: str, msg: str) -> bool:
        sha = await self.get_sha(path)
        try:
            enc = base64.b64encode(content.encode("utf-8", "replace")).decode()
        except Exception:
            enc = base64.b64encode(content.encode("ascii", "replace")).decode()

        payload: dict = {
            "message": msg,
            "content": enc,
            "branch" : BRANCH,
        }
        if sha:
            payload["sha"] = sha

        url = f"{BASE_URL}/contents/{path}"
        try:
            async with self.session.put(url, headers=HEADERS,
                                        json=payload) as r:
                if r.status in (200, 201):
                    d   = await r.json()
                    new = d.get("content", {}).get("sha")
                    if new:
                        self.sha_cache[path] = new
                    self.pushed += 1
                    return True
                if r.status == 422:
                    # Conflict — clear cache and retry once
                    self.sha_cache.pop(path, None)
                    return False
                if r.status == 429:
                    self.rate_hits += 1
                    await asyncio.sleep(3)
                self.failed += 1
                return False
        except Exception as e:
            self.failed += 1
            return False


