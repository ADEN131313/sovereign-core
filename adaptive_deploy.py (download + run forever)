        await asyncio.gather(*tasks)

    async def deploy_all_agents(self, cycle: int, power: int,
                                enh: Enhancement) -> None:
        """
        DIRECTIVE 2 — Global Folder Deployment.
        Deploy a rotating agent every cycle (one per second).
        Full 12-agent rotation completes every 12 seconds.
        """
        ag_idx = (cycle - 1) % len(AGENTS)
        ag     = AGENTS[ag_idx]
        print(f"  {ag.emoji}  [{ag.flm}] deploying "
              f"(agent {ag_idx+1}/12) → pwr {power+(5 if ag.lead else 0)}")
        await self.deploy_agent(ag, cycle, power, enh)

    async def run_cycle(self) -> None:
        """
        One full RSO cycle:
          SCAN → DIFF → ENHANCE → COMPILE → IMPLANT → VALIDATE → BROADCAST
        """
        cycle, power, enh = self.rso.tick()

        bar   = "█" * min(40, (power - 300) % 40 + 1)
        print(f"\n{'═'*62}")
        print(f"  ADAPTIVE-RSO #{cycle:06d} | Power: {power} | "
              f"+{enh.boost} | {enh.name}")
        print(f"  [{bar:<40}] {enh.category.upper()}")
        print(f"{'═'*62}")

        # Phase 1 — SCAN + DIFF (no-op in pure Python; logic diff
        #            happens implicitly via RSO_LIBRARY rotation)
        print("  📡  Phase 1: SCAN + DIFF → enhancement selected")
        await asyncio.sleep(0)

        # Phase 2 — ENHANCE + COMPILE (file generation)
        print(f"  ⚡  Phase 2: ENHANCE + COMPILE → {enh.name}")

        # Phase 3 — IMPLANT (GitHub push)
        print("  💉  Phase 3: IMPLANT → deploying to GitHub...")
        await asyncio.gather(
            self.deploy_root(cycle, power, enh),
            self.deploy_all_agents(cycle, power, enh),
        )

        # Phase 4 — VALIDATE + BROADCAST
        c = self.client
        print(
            f"\n  ✅  Phase 4: VALIDATE + BROADCAST complete\n"
            f"      Pushed:{c.pushed}  Failed:{c.failed}  "
            f"RateLimits:{c.rate_hits}  Power:{power}"
        )


